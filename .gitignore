# ====================================================================
# Data directory
# Strategy: ignore the large cohorts (GB+) but keep small reference files
# and example inputs so the demo pipeline is reproducible out-of-the-box.
# Please see README "Data acquisition" for full download instructions.
# ====================================================================
data/CCLE2019/
data/cellwhisper/
data/GDAC/
data/pretraining_data/

# Within data/example_input/: keep small demo CSVs but ignore generated artifacts
data/example_input/preprocessed_metadata.json
data/example_input/textual_annotations_*.json
# Re-include a small, hand-curated example file (when present) for the demo:
!data/example_input/textual_annotations_example.json

# ====================================================================
# Modules not included in this public release
# ====================================================================
code/explainable_summary_generation/
code/omix/Youtu_embedding/

